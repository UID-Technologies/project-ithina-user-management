# Copy to deploy/.env and set PUBLIC_HOST to your Azure VM public IP or domain.
# Example: PUBLIC_HOST=20.123.45.67

PUBLIC_HOST=YOUR_VM_PUBLIC_IP_OR_DOMAIN

# Host ports exposed on the VM
WEB_PORT=8080
API_PORT=3002

# Frontend build-time API URL (browser must reach this address)
VITE_API_BASE_URL=http://YOUR_VM_PUBLIC_IP_OR_DOMAIN:3002

# API CORS — must match the URL users open in the browser
CORS_ORIGIN=http://YOUR_VM_PUBLIC_IP_OR_DOMAIN:8080

# MongoDB is internal only (service name "mongo" on the Docker network).
# The API uses: mongodb://mongo:27017/ithina-user-management

# Security — change before production
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=8h
LOG_LEVEL=info

# Demo login credentials (seeded data)
SEED_ADMIN_EMAIL=anjali@ithina.ai
SEED_ADMIN_PASSWORD=SuperAdmin123!
VITE_SUPERADMIN_EMAIL=anjali@ithina.ai
VITE_SUPERADMIN_PASSWORD=SuperAdmin123!
