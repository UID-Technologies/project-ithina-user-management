{
  "name": "user-management-api",
  "version": "1.0.0",
  "description": "Enterprise user management API for Ithina Superadmin Console",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "seed": "tsx scripts/seed.ts",
    "seed:prod": "node dist/seed/seed.js",
    "clean": "tsx scripts/clean.ts",
    "db:seed": "npm run seed",
    "db:clean": "npm run clean",
    "db:reset": "npm run clean && npm run seed",
    "indexes": "tsx scripts/create-indexes.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "lint": "tsc --noEmit"
  },
  "keywords": ["express", "mongodb", "rbac", "superadmin"],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
